{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": [
    "extensions/**/*.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts"
  ]
}
