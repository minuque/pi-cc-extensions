{
  "name": "pi-cc-extensions",
  "version": "0.7.10",
  "description": "A Pi productivity suite with Claude Code-style UI, context inspection, and agent/session references",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "claude-code"
  ],
  "homepage": "https://github.com/minuque/pi-cc-extensions#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minuque/pi-cc-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/minuque/pi-cc-extensions/issues"
  },
  "files": [
    "extensions",
    "assets/readme",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/claude-code-style.ts",
      "./extensions/context.ts",
      "./extensions/session-reference.ts",
      "./extensions/agent-autocomplete.ts"
    ],
    "image": "https://raw.githubusercontent.com/minuque/pi-cc-extensions/main/assets/readme/fixed-editor-navigation.webp"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.ts",
    "typecheck": "node scripts/typecheck.mjs",
    "preversion": "npm run typecheck && npm test",
    "release": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
